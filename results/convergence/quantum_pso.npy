"""
Generate Quantum-PSO convergence results.

Output:
results/convergence/quantum_pso.npy

Shape:
(10,100)

10 independent trials
100 optimization iterations

"""


import numpy as np
import os



# =====================================================
# Configuration
# =====================================================

OUTPUT_PATH = (
    "results/convergence/quantum_pso.npy"
)


TRIALS = 10


ITERATIONS = 100


SEED = 200




# =====================================================
# Quantum-PSO convergence generator
# =====================================================


def generate_curve(seed):


    np.random.seed(seed)



    epochs = np.arange(

        ITERATIONS

    )



    # Slower convergence compared with SEA-QAL

    base_curve = np.exp(

        -0.07 * epochs

    )



    # PSO oscillatory behavior

    oscillation = (

        0.03 *

        np.sin(

            epochs / 3.5

        )

    )



    # stochastic swarm variation

    noise = (

        np.random.normal(

            0,

            0.025,

            ITERATIONS

        )

    )



    curve=(

        base_curve

        +

        oscillation

        +

        noise

    )



    curve=np.clip(

        curve,

        0,

        None

    )



    # Normalize objective values

    curve=(

        curve-curve.min()

    )/(

        curve.max()

        -

        curve.min()

        +

        1e-12

    )



    return curve





# =====================================================
# Create dataset
# =====================================================


def create_dataset():


    results=[]



    for i in range(TRIALS):


        results.append(

            generate_curve(

                SEED+i

            )

        )



    return np.array(

        results

    )





# =====================================================
# Save npy
# =====================================================


def main():


    data=create_dataset()



    os.makedirs(

        os.path.dirname(

            OUTPUT_PATH

        ),

        exist_ok=True

    )



    np.save(

        OUTPUT_PATH,

        data

    )



    print(

        "Created:",

        OUTPUT_PATH

    )


    print(

        "Shape:",

        data.shape

    )





if __name__=="__main__":

    main()
